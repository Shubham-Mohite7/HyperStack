# Groq API credentials
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model selection — llama-3.3-70b-versatile recommended for highest accuracy
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | gpt-oss-120b | gpt-oss-20b
GROQ_MODEL=llama-3.3-70b-versatile

# Server port for local development
PORT=3001

# Client origin for CORS — update this to your Vercel domain in production
CLIENT_ORIGIN=https://your-project.vercel.app
